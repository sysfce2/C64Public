!to "bin/maincart.bin", plain
!sal
!sl "tmp/maincart.map"
!svl "tmp/maincart.lbl"
!pdb "tmp/maincart.pdb"
!cpu 6510
!ct pet

!source "stdlib/stdlib.a"
!source "stdlib/Comparisons.a"

!zn
*=C64Cartridge_Lo_8K
!word start
!word start
+M_CBM80

.c64Reminder
	!scr "MegaWang 2000 Turbo Edition hardware"
.c64ReminderEnd
.c64Reminder2
	!scr "Cart boot"
.c64ReminderEnd2

start
	+MStopInitStack_X
	jsr DoDataToTop
	jmp DataToTopStartReal

DataToTopStart
!pseudopc $c000 {
DataToTopStartReal
	lda #ProcessorPortDefault
	sta ZPProcessorPort
	lda #ProcessorPortDDRDefault
	sta ZPProcessorPortDDR

	lda #ProcessorPortDefault
	jsr InitialiseMachine

	; Ensure the cartridge bank, although this should be 0,0 at power-on reset anyway
	lda #0
	sta MemoryMappedIOArea1
	sta MemoryMappedIOArea2

	+SetDefaultScreenLowerCase_A
	+ClearScreenAt_AX SCREENRAM , ' '
	+ClearScreenAt_AX COLOURRAM , VIC2Colour_Black
	+DisplayColourTextMiddle_AX .c64Reminder , .c64ReminderEnd , SCREENRAM , VIC2Colour_White
	+DisplayColourTextMiddle_AX .c64Reminder2 , .c64ReminderEnd2 , SCREENRAM + VIC2ScreenCharsWidth , VIC2Colour_LightGreen

	+MWordValueTo_XY BootCode
	jsr MemoryCopy_SetSource
	+MWordValueTo_XY BASICSTART
	jsr MemoryCopy_SetDestination
	+MWordValueTo_XY BootCodeEnd - BootCode
	jsr MemoryCopy_ForSize

	jmp 2061

Initialise_NoPreserveStack = 1
Initialise_NoIRQServiceRoutine = 1
Initialise_NoMACROWaitForTheLastScan = 1
!source "stdlib/Initialise.a"
!source "stdlib/MemoryCopy.a"

+MCheckNotInIOKernal
DataToTopEndReal
}

DataToTopEnd
DataToTopSize = DataToTopEnd - DataToTopStart

!if DataToTopEndReal >= VIC {
!error "DataToTopEndReal is over VIC"
}

!zn
DoDataToTop
	ldx #0
.cl1
!for .i , (>DataToTopSize)+1 {
!set .ii = .i - 1
	lda DataToTopStart + (.ii * $100),x
	sta DataToTopStartReal + (.ii * $100),x
}
	dex
	bne .cl1
	rts

BootCode
!bin "bin/main.cmp2.prg",,2
BootCodeEnd
+MCheckNotInBASICUpwards

+MCheckNotInKERNALServiceVectors
