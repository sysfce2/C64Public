kAPUNumRunwayRows = 240-15

!zn
TotalAPU_Start

APUCode_Start
!pseudopc 0 {
frameStart0
	+MAPU
	+MAPU kAPU_Reset_ADDRB1

	; Get EBSEADDR values
	+MAPU kAPU_Load_EBS
	+MAPU kAPU_Incr_ADDRB1

	; Mode7 changes
	+MAPU_LoadDoWait
	+MAPU_LoadEADDRFromB1
!for .i , 6 * 3 {
	+MAPU kAPU_ExternalMEWR
	+MAPU kAPU_Incr_ADDRB1 | kAPU_Incr_EADDR
}

	; Get EBSEADDR values
	+MAPU kAPU_Load_EBS | kAPU_Load_EBS2
	+MAPU kAPU_Incr_ADDRB1

	; Load APULineScrolls
	; For line scrolls
	+MAPU kAPU_IDataRegLoad0
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataRegLoad1
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_ADDRB2Load16

	; Decide to run the runway or hiscore
	+MAPU kAPU_IDataRegLoad2
	+MAPU kAPU_Incr_ADDRB1
	; APUHiscoreSections
	+MAPU kAPU_IDataRegLoad0
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataRegLoad1
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataSelectReg2
	+MAPU kAPU_PCLoad16 | kAPU_SkipIfEQ | kAPU_IDataSelectReg2
	+MAPU

	; Skip the hiscore data pointer
	+MAPU kAPU_Incr_ADDRB1
	+MAPU
	+MAPU kAPU_Incr_ADDRB1

	; Top of screen
	+MAPU_LoadDoWait
	+MAPU_ProcessRasterWord

	; During the Runway update
	; ADDRB1 = APULineWaits
	; ADDRB2 = APULineScrolls

	; Runway
	; For <kBus24Bit_TileScreen_ScrollY16
	+MAPU kAPU_IDataRegLoad2
	+MAPU kAPU_Incr_ADDRB1
	; APURunwayLoop
	+MAPU kAPU_IDataRegLoad0
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataRegLoad1
	+MAPU kAPU_Incr_ADDRB1
	; kAPUNumRunwayRows and 1
	+MAPU kAPU_IDataRegLoad3
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataRegLoad4
	+MAPU kAPU_Incr_ADDRB1

	; APULineScrolls
	; Remaining lines
APURunwayLoop
	+MAPU
	+MAPU_LoadDoWait

	; Restore EADDRLo
	+MAPU kAPU_Load_EADDRLo | kAPU_IDataSelectReg2
	+MAPU_ProcessWordB2

	+MAPU kAPU_IDataSelectReg3SubReg4 | kAPU_IDataRegLoad3
	+MAPU kAPU_IDataSelectReg3
	+MAPU kAPU_PCLoad16 | kAPU_SkipIfEQ | kAPU_IDataSelectReg3
	+MAPU

	+MAPU kAPU_Reset_PC
	+MAPU


APUHiscoreSections
	+MAPU

	; Hiscore setup
	; Load hiscore data pointer
	+MAPU kAPU_IDataRegLoad0
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataRegLoad1
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_ADDRB1Load16

	; Decide to just exit the hiscore draw, for the title screen intro...
	+MAPU kAPU_IDataRegLoad2
	+MAPU kAPU_Incr_ADDRB1
	+MAPU kAPU_IDataSelectReg2
	; NOTE: APU: Real hardware: This fails, it always chooses reset even when reg2 is 0
;	+MAPU kAPU_Reset_PC | kAPU_SkipIfEQ | kAPU_IDataSelectReg2
	+MAPU

	; Turn off the char screen
	+MAPU_ProcessRasterByte
	; Wait for the split position and enable the screen
	+MAPU_LoadDoWait
	+MAPU_ProcessRasterByte

	; Hiscore sections
!for .i , NumScoreTableEntries {
	+MAPU_LoadDoWait
	+MAPU_ProcessRasterWord
}

	+MAPU kAPU_Reset_PC
	+MAPU

}

APUCode_Size = *-APUCode_Start

!if APUCode_Size > 8192 {
	!error "APUCode_Size too large"
}

APUData_Start
	!by kBus24Bit_Mode7Screen_EBBS

	; Next RHRV to wait for, the start of the VBlank
APUData_VBlankYPos = * + 2
APUData_VBlankYPos_Value = $f0
	+MAPU_EmitWait 0 , APUData_VBlankYPos_Value
	+MLittleEndian16Bit kBus24Bit_Mode7Screen_Registers
APUData_Start_Mode7Registers
	; dx
	!by 0 , $1 , 0
	; dxy
	!by 0 , 0 , 0
	; dy
	!by 0 , $1 , 0
	; dyx
	!by 0 , 0 , 0
	; xpos
	!by 0 , 0 , 0
	; ypos
	!by 0 , 0 , 0

	; Get EBSEADDR values
	!by $01
	; For line scrolls
	+MLittleEndian16Bit APULineScrolls - APUData_Start

	; Decide to run the runway or hiscore
APUHiscoreOrRunwayFlag
	!by 0	; 0 = runway
	!word APUHiscoreSections / kAPU_InstructionSize
	; Load hiscore data pointer
	; Skip the hiscore data pointer
	!word APUHiscoreData - APUData_Start

	; Top of screen
	+MAPU_EmitWait kBus24Bit_VideoLayer_XPos_HSYNC_start - kMAPUEmitChangePaletteIndexHSyncAdjust , 12
	; And reset the kBus24Bit_TileScreen_ScrollY16
	+MLittleEndian16Bit kBus24Bit_TileScreen_ScrollY16
	!word -1

	; Runway
	!by <kBus24Bit_TileScreen_ScrollY16
	!word APURunwayLoop / kAPU_InstructionSize
	!by kAPUNumRunwayRows
	!by 1

	; Remaining lines
APULineWaits
!for .i , kAPUNumRunwayRows {
	+MAPU_EmitWait kBus24Bit_VideoLayer_XPos_HSYNC_start , 14 + .i -1
}

APULineScrolls
!for .i , kAPUNumRunwayRows {
	!word -((.i-1)+15) + 0					; Selects row 0, the empty line
;	!word -((.i-1)+15) + 1					; Selects row 1, the one pixel line
;	!word -((.i-1)+15) + (.i & $f)			; Selects a pattern
;	!word -((.i-1)+15) + (.i & $f) + $40	; Selects a pattern
;	!word -((.i-1)+15) + (.i & $f) + $80	; Selects a pattern
}

APUHiscoreData

APUHiscoreOrExitFlag
	; Decide to just exit the hiscore draw, for the title screen intro...
	!by 1	; 0 = Run the hiscore

	; Turn off the char screen
	!word kBus24Bit_VideoLayer_LayersEnable
	!by kBus24Bit_VideoLayer_LayersEnable_134

	; Wait for the split position and enable the screen
APUScoreTableTopSplitPos = * + MAPU_EmitWait_offset_ypos
	+MAPU_EmitWait kBus24Bit_VideoLayer_XPos_HSYNC_start , 15
	!word kBus24Bit_VideoLayer_LayersEnable
	!by kBus24Bit_VideoLayer_LayersEnable_1234

APUScoreTablePosY1 = * + 2
APUScoreTablePosX1 = * + 5
APUScoreTablePos_size = 7
	; Hiscore sections
!for .i , NumScoreTableEntries {
	+MAPU_EmitWait kBus24Bit_VideoLayer_XPos_HSYNC_start , 180 + .i
	+MLittleEndian16Bit kBus24Bit_CharScreen_ScrollX16
	+MLittleEndian16Bit -432 + (.i * 32)
}

APUData_End
APUData_Size = APUData_End - APUData_Start

!if APUData_Size > 8192 {
	!error "APUData_Size too large"
}

TotalAPU_Size = * - TotalAPU_Start
