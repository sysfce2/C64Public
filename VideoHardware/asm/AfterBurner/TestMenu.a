!macro MMenuDrawOption .option , .end , .eor , .flash , .flashEnd {
	cmp #.option
	bne .not0
	lda .eor
	and #8
	beq .is0
	jsr .flashEnd
	jmp .end
.is0
	jsr .flash
	jmp .end
.not0
}
	+MMenuDrawOption 0 , .end , .eor , .flash0 , .flashEnd0
	+MMenuDrawOption 1 , .end , .eor , .flash1 , .flashEnd1
